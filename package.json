{
  "name": "ashen-requiem",
  "version": "1.0.0",
  "description": "HTML / JavaScript vampire-survivors-like game",
  "type": "module",
  "scripts": {
    "test": "node scripts/runTests.js",
    "test:watch": "node --watch scripts/runTests.js",
    "test:smoke": "node scripts/browser-smoke/runSmokeAgainstPreview.mjs --suite core",
    "test:smoke:full": "node scripts/browser-smoke/runSmokeAgainstPreview.mjs --all",
    "smoke:core:prebuilt": "node scripts/browser-smoke/runSmokeAgainstPreview.mjs --suite core --skip-build",
    "smoke:full:prebuilt": "node scripts/browser-smoke/runSmokeAgainstPreview.mjs --all --skip-build",
    "validate": "node scripts/validateData.js",
    "lint": "npm run lint:architecture",
    "lint:architecture": "npm run lint:eslint && npm run check:boundaries && npm run check:architecture-docs",
    "lint:eslint": "eslint .",
    "check:boundaries": "node scripts/checkBoundaries.js",
    "check:architecture-docs": "node scripts/checkArchitectureDocs.mjs",
    "pretest": "node scripts/validateData.js",
    "typecheck": "tsc -p tsconfig.typecheck.json --pretty false",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "architecture:snapshot": "node scripts/architectureSnapshot.mjs",
    "compatibility:wrappers": "node scripts/compatibilityWrappers.mjs",
    "verify": "npm run verify:fast",
    "verify:fast": "npm run typecheck && npm run profile:check && npm run lint && npm test && npm run build",
    "verify:ci": "npm run typecheck && npm run profile:check && npm run lint && npm test && npm run build && npm run smoke:core:prebuilt",
    "profile": "node scripts/profile.js",
    "profile:600": "node scripts/profile.js 600",
    "profile:json": "node scripts/profile.js 300 --json",
    "profile:check": "node scripts/profile.js 300 --assert-budget",
    "encounter:report": "node scripts/encounterReport.mjs",
    "verify:smoke": "npm run build && npm run smoke:core:prebuilt"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/cli": "^0.1.3",
    "eslint": "^10.1.0",
    "typescript": "^5.9.2",
    "vite": "^8.0.0"
  }
}
