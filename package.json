{
  "name": "ashen-requiem",
  "version": "1.0.0",
  "description": "HTML / JavaScript vampire-survivors-like MVP",
  "type": "module",
  "scripts": {
    "test": "node scripts/runTests.js",
    "test:watch": "node --watch scripts/runTests.js",
    "test:smoke": "node scripts/browser-smoke/runSmokeAgainstPreview.mjs --all",
    "validate": "node scripts/validateData.js",
    "pretest": "node scripts/validateData.js",
    "typecheck": "tsc -p tsconfig.typecheck.json --pretty false",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "verify": "npm run typecheck && npm test && npm run test:smoke && npm run build",
    "profile": "node scripts/profile.js",
    "profile:600": "node scripts/profile.js 600",
    "profile:json": "node scripts/profile.js 300 --json"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "typescript": "^5.9.2",
    "vite": "^8.0.0"
  }
}
